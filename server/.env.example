# Copy to .env and fill in. All values are optional for local dev.

# Port the server listens on
PORT=4000

# Secret used to sign login tokens — set a long random string in production
JWT_SECRET=change-me-to-a-long-random-string

# Where the SQLite database file lives (use a mounted volume in production)
# DB_PATH=/data/dainty.db

# Web Push (free). Generate with: npm run keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Set to your local timezone so daily/weekly rollovers happen at your midnight
# TZ=America/New_York
